<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F5F9">


    <!-- ══ SCROLLABLE CONTENT ══ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ══ BUDGET SUMMARY CARD ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- "Total Budget" label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Budget"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />

                <!-- Big purple budget amount -->
                <TextView
                    android:id="@+id/tvTotalBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0.00"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#5B4FE9"
                    android:layout_marginBottom="12dp" />

                <!-- Thin divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="12dp" />

                <!-- Period row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:gravity="center_vertical">

                    <!-- Left: spinner + date range -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <Spinner
                            android:id="@+id/spinnerGraphPeriod"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:background="@android:color/transparent"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPeriodLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:fontFamily="monospace" />
                    </LinearLayout>

                    <!-- Right: label + main value + sub value -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvTrendLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Spent"
                            android:textSize="11sp"
                            android:textColor="#9E9E9E"
                            android:gravity="end" />

                        <TextView
                            android:id="@+id/tvTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#E53935"
                            android:gravity="end" />

                        <TextView
                            android:id="@+id/tvTrendSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D32"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ══ VIEW MODE TOGGLE ══ -->
            <RadioGroup
                android:id="@+id/rgViewMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="8dp">

                <RadioButton
                    android:id="@+id/rbDaily"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:buttonTint="#5B4FE9"
                    android:checked="true"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/tab_daily"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp" />

                <RadioButton
                    android:id="@+id/rbCategory"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:buttonTint="#5B4FE9"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="@string/tab_by_category"
                    android:textColor="#1A1A2E"
                    android:textSize="13sp" />
            </RadioGroup>

            <!-- ══ GOAL STATUS BANNER ══ -->
            <LinearLayout
                android:id="@+id/layoutGoalStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#EDF7ED"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/goal_emoji"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvGoalStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#1A1A2E" />
            </LinearLayout>

            <!-- ══ CHART CARD ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvChartTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/tvChartSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chart_subtitle"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="12dp" />

                <com.budgetbuddy.app.BarChartView
                    android:id="@+id/barChartView"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:background="#FFFFFF" />
            </LinearLayout>

            <!-- ══ DETAIL LIST (category rows / daily rows) ══ -->
            <LinearLayout
                android:id="@+id/llLegend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginBottom="8dp" />

            <!-- ══ LINE LEGEND (dashed line explanations) ══ -->
            <LinearLayout
                android:id="@+id/llLineLegend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- ══ TOTAL SPENT FOOTER ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total_spent_label"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#5B4FE9" />

                <TextView
                    android:id="@+id/tvTotalSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0.00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#5B4FE9" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>