<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_header"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Logo area -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰"
            android:textSize="52sp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BudgetBuddy"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track it. Own it. Win it."
            android:textColor="#D0B8FF"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <!-- White form card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvAuthTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back"
                android:textColor="#1A1A2E"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Username"
                android:textColorHint="#BDBDBD"
                android:textColor="#1A1A2E"
                android:background="@drawable/input_border_gray"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Password (min 8 characters)"
                android:textColorHint="#BDBDBD"
                android:textColor="#1A1A2E"
                android:background="@drawable/input_border_gray"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvConfirmLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Password"
                android:textColor="#757575"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Confirm Password"
                android:textColorHint="#BDBDBD"
                android:textColor="#1A1A2E"
                android:background="@drawable/input_border_gray"
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="15sp"
                android:visibility="gone"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btnAuthAction"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Login"
                android:background="@drawable/gradient_button"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/tvSwitchMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? Register"
                android:textColor="#6B4EFF"
                android:textSize="14sp"
                android:layout_gravity="center_horizontal"
                android:padding="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>