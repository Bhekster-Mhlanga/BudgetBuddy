<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F8">

    <!-- ══ PERIOD FILTER CARD ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackground"
        android:elevation="2dp"
        android:padding="14dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

        <!-- Solid white underlay so ripple shows over white -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="20sp"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <Spinner
                android:id="@+id/spinnerPeriod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/tvDateRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Chevron down — signals this row opens a dropdown -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▾"
            android:textSize="18sp"
            android:textColor="#9E9E9E"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnCustomDate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Filter"
            android:backgroundTint="#FFFFFF"
            android:textColor="#6B4EFF"
            android:textSize="12sp"
            android:visibility="gone"
            android:elevation="1dp"
            android:stateListAnimator="@null"
            android:drawableStart="@android:drawable/ic_menu_sort_by_size" />
    </LinearLayout>

    <!-- ══ TRANSACTIONS TABLE ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp">

        <!-- Dark header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:background="#1E2A3A"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transactions"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvExpenseTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: R0.00"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:background="#FF8C00"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>

        <!-- Column headers: DATE | DESCRIPTION | 📷 | CATEGORY | AMOUNT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical"
            android:background="#F8F9FA">

            <TextView
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="DATE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DESCRIPTION"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:text="CATEGORY"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:gravity="center"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="AMOUNT"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:gravity="end"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- Expense rows -->
        <ListView
            android:id="@+id/lvExpenses"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="#F0F0F0"
            android:dividerHeight="1dp"
            android:background="#FFFFFF" />
    </LinearLayout>

    <!-- ══ BOTTOM BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvRowCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 entries"
            android:textSize="12sp"
            android:textColor="#9E9E9E" />

        <Button
            android:id="@+id/btnCategoryTotals"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:backgroundTint="#FF8C00"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:stateListAnimator="@null"
            android:text="Category Totals"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>